{
  "name": "n8n-nodes-boilerplate",
  "version": "0.1.0",
  "description": "Boilerplate for an n8n community node (v1+).",
  "author": "Max Soukhomlinov <maxs@intellectit.com.au>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msoukhomlinov/n8n-nodes-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/msoukhomlinov/n8n-nodes-boilerplate/issues"
  },
  "homepage": "https://github.com/msoukhomlinov/n8n-nodes-boilerplate#readme",
  "keywords": [
    "n8n",
    "n8n-community-node",
    "n8n-community-node-package",
    "workflow",
    "integration"
  ],
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && gulp build:icons",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.41.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "gulp": "^4.0.2",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ExampleApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Boilerplate/Boilerplate.node.js",
      "dist/nodes/Boilerplate/BoilerplateAiTools.node.js"
    ]
  }
}


